{
  "name": "fundtrust-backend",
  "version": "1.0.0",
  "description": "Backend API for the Non-Profit Donation Platform",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node seed/seed.js",
    "test:quick": "dotenv -e artillery/.env.test -- artillery run artillery/quick-test.yml",
    "test:load": "dotenv -e artillery/.env.test -- artillery run artillery/load-test.yml",
    "test:prod": "dotenv -e artillery/.env.test -- artillery run artillery/production-test.yml",
    "test:report": "dotenv -e artillery/.env.test -- artillery run --output artillery/report.json artillery/load-test.yml && artillery report artillery/report.json"
  },
  "keywords": [
    "donations",
    "non-profit",
    "stripe",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.1",
    "resend": "^6.10.0",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "artillery": "^2.0.30",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.11"
  }
}
